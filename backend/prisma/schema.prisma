generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Favorite {
  id         String   @id @default(uuid())
  title      String
  type       String
  nasaId     String?
  imageUrl   String?
  notes      String?
  tags       String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
