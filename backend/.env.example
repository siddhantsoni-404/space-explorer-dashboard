# PostgreSQL connection string
# Replace 'password' with your actual postgres password if you are running it locally.
DATABASE_URL=postgresql://postgres:password@localhost:5432/space_explorer

# Server Port
PORT=5000

# NASA API Key (Get yours for free at https://api.nasa.gov/)
# By default DEMO_KEY works but has strict rate limits (30-50 requests per hour).
NASA_API_KEY=DEMO_KEY
